    "name": "Tiendanube / Nuvemshop API",
    "version": "1.0"
  },
  "request": {
    "auth": {
      "type": "apikey",
      "apikey": {
        "key": "Authentication",
        "value": "bearer {{accessToken}}",
        "in": "header"
      }
    }
